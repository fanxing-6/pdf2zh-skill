# Required for DOC2X PDF parsing. arXiv source packages and --project runs may not need it.
DOC2X_API_KEY=

# Required for translation. The endpoint must be OpenAI Chat Completions compatible.
PDF2ZH_TRANSLATION_API_KEY=
PDF2ZH_TRANSLATION_BASE_URL=
PDF2ZH_TRANSLATION_MODEL=

# Optional
# PDF2ZH_SKILL_HOME=
# PDF2ZH_SKILL_TMPDIR=
# PDF2ZH_SKILL_ENV_FILE=
# MATHPIX_APPID=
# MATHPIX_APPKEY=
